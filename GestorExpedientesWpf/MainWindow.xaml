<Window x:Class="GestorExpedientesWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:GestorExpedientesWpf"
        xmlns:viewModel="clr-namespace:GestorExpedientesWpf.ViewModels"
        xmlns:converters="clr-namespace:GestorExpedientesWpf.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Gestión de expedientes" MinHeight="800" MinWidth="1200"
        Background="{StaticResource PageBgBrush}" FontFamily="Segoe UI">

    <Window.DataContext>
        <viewModel:ExpedientesViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:NullToDefaultUrlConverter x:Key="NullToDefaultUrlConverter"/>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- Document type color coding -->
        <Style x:Key="TipoDocumentoCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Autorización">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Informe">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Factura">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Stats text -->
        <Style x:Key="CountTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Orphan row highlight -->
        <Style x:Key="OrphanRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOrphan}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Form styles -->
        <Style x:Key="FormTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- BooleanToContentConverter with edit/query modes -->
        <converters:BooleanToContentConverter x:Key="BooleanToContentConverter">
            <!-- MODO EDICIÓN -->
            <converters:BooleanToContentConverter.TrueContent>
                <Grid>
                    <GroupBox Margin="0,0,10,10">
                        <GroupBox.Header>
                            <TextBlock Text="Edición de metadatos" Style="{StaticResource SectionTitle}"/>
                        </GroupBox.Header>
                        <Grid Margin="10">
                            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="No. Autorización:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="5,4" Width="150" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoAutorizacion}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cobertura:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5,4" Width="400" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.Cobertura}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="NIF Mutua:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="5,4" Width="150" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NIFMutua}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Nombre Paciente:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="5,4" Width="400" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NombrePaciente}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="DNI Paciente:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Margin="5,4" Width="150" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.DNIPaciente}"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Fecha Factura:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <DatePicker Grid.Row="5" Grid.Column="1" Margin="5,4" Width="200" HorizontalAlignment="Left" FontSize="14"
                                             SelectedDate="{Binding EditExpediente.FechaFactura}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="No. Factura:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="6" Grid.Column="1" Margin="5,4" Width="150" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoFactura}"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Remesa:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="7" Grid.Column="1" Margin="5,4" Width="150" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.Remesa}"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Cobertura Informe:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="8" Grid.Column="1" Margin="5,4" Width="400" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.CoberturaInforme}"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Fecha Acto:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <DatePicker Grid.Row="9" Grid.Column="1" Margin="5,4" Width="200" HorizontalAlignment="Left" FontSize="14"
                                             SelectedDate="{Binding EditExpediente.FechaActo}"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="No. Acto:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="10" Grid.Column="1" Margin="5,4" Width="400" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoActo}"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="11" Grid.Column="1" Margin="0,12,0,0">
                                        <Button Content="Asignar" Command="{Binding SetMetadataCommand}" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="5" Padding="16,8"/>
                                        <Button Content="Cancelar" Command="{Binding CancelEditMetadataCommand}" Background="{StaticResource SplitterBrush}" Foreground="White" Margin="5" Padding="16,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </converters:BooleanToContentConverter.TrueContent>

            <converters:BooleanToContentConverter.FalseContent>
                <!-- MODO CONSULTA -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1" Margin="0,0,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Resultado consulta" Style="{StaticResource SectionTitle}" Grid.Row="0"/>

                        <xctk:BusyIndicator IsBusy="{Binding IsBusy}" BusyContent="Actualizando..." Grid.Row="1">
                            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding ExpedientesView}"
                                      IsReadOnly="True" RowStyle="{StaticResource OrphanRowStyle}"
                                      MouseDoubleClick="ResultadosDataGrid_MouseDoubleClick"
                                      SelectedItem="{Binding SelectedExpediente}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tipo Documento" Binding="{Binding TipoDoc}" CellStyle="{StaticResource TipoDocumentoCellStyle}"/>
                                    <DataGridTextColumn Header="No Autorización" Binding="{Binding NoAutorizacion}"/>
                                    <DataGridTextColumn Header="Fecha Creación" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}"/>
                                    <DataGridTextColumn Header="Cobertura" Binding="{Binding Cobertura}"/>
                                    <DataGridTextColumn Header="NIF Mutua" Binding="{Binding NIFMutua}"/>
                                    <DataGridTextColumn Header="Nombre Paciente" Binding="{Binding NombrePaciente}"/>
                                    <DataGridTextColumn Header="DNI Paciente" Binding="{Binding DNIPaciente}"/>
                                    <DataGridTextColumn Header="Fecha Factura" Binding="{Binding FechaFactura, StringFormat=dd/MM/yyyy}"/>
                                    <DataGridTextColumn Header="No Factura" Binding="{Binding NoFactura}"/>
                                    <DataGridTextColumn Header="Fecha Acto" Binding="{Binding FechaActo, StringFormat=dd/MM/yyyy}"/>
                                    <DataGridTextColumn Header="No Acto" Binding="{Binding NoActo}"/>
                                    <DataGridTextColumn Header="Remesa" Binding="{Binding Remesa}"/>
                                    <DataGridTextColumn Header="Cobertura Informe" Binding="{Binding CoberturaInforme}"/>
                                    <DataGridTemplateColumn Header="Añadir">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.AddSeleccionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Background="{StaticResource SuccessBrush}" Foreground="White" Padding="6,3">
                                                    <Image Source="pack://application:,,,/GestorExpedientesWpf;component/Resources/add.png" Width="16" Height="16"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </xctk:BusyIndicator>
                    </Grid>
                </Grid>
            </converters:BooleanToContentConverter.FalseContent>
        </converters:BooleanToContentConverter>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Splitter -->
        <GridSplitter Grid.Column="0" Width="6" HorizontalAlignment="Right" Background="{StaticResource SplitterBrush}"
                      ToolTip="Ajustar tamaño" Cursor="SizeWE">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="0,8"/>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- COLUMNA IZQUIERDA -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Panel de filtros -->
            <GroupBox Header="Selección de documentos" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical" Margin="0,6,0,0">
                        <CheckBox Content="Aplicar filtro de fechas" Margin="0,5,0,0" Name="chkFechaFiltro" IsChecked="{Binding AplicarFiltroFechas}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaInicio}"/>
                            <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaFin}"/>
                            <Button Content="Actualizar" Margin="10,0,0,0" Width="100" Command="{Binding ActualizarCommand}"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" Click="Button_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Cobertura:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txtMutuas" Width="400" VerticalAlignment="Center" HorizontalAlignment="Left"
                                     Text="{Binding FiltroMutua, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="txtMutuas_KeyDown"
                                     MouseDoubleClick="txtMutuas_MouseDoubleClick"
                                     TextChanged="txtMutuas_TextChanged"/>
                            <Popup x:Name="popupMutuas"
                                   PlacementTarget="{Binding ElementName=txtMutuas}"
                                   Placement="Bottom" IsOpen="False" StaysOpen="False">
                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                                        Effect="{StaticResource {x:Static SystemParameters.DropShadowEffectKey}}">
                                    <ListBox x:Name="lstMutuas"
                                             ItemsSource="{Binding MutuasFiltradas}"
                                             MouseDoubleClick="lstMutuas_MouseDoubleClick"
                                             KeyDown="lstMutuas_KeyDown"
                                             MaxHeight="200"/>
                                </Border>
                            </Popup>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                            <CheckBox Content="Mostrar solo documentos huérfanos" IsChecked="{Binding MostrarSoloDocumentosHuerfanos}" Margin="0,0,16,0"/>
                            <CheckBox Content="Ignorar documentos con remesa" IsChecked="{Binding IgnorarDocumentosConRemesa}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Panel de estadísticas -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Padding="16,12" CornerRadius="8">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding TotalDocumentos, StringFormat='Total expedientes: {0}'}"
                                           Style="{StaticResource CountTextStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding AutorizacionesCount, StringFormat='Autorizaciones: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="{Binding InformesCount, StringFormat='Informes: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="{Binding FacturasCount, StringFormat='Facturas: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Resultados / Edición -->
            <ContentControl Grid.Row="1" Content="{Binding EditMetadataMode, Converter={StaticResource BooleanToContentConverter}}"/>

            <!-- Seleccionados -->
            <Grid Grid.Row="2" Margin="0,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Selección" Style="{StaticResource SectionTitle}" Grid.Row="0"/>
                <DataGrid AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Seleccionados}" Grid.Row="1"
                          RowStyle="{StaticResource OrphanRowStyle}" MouseDoubleClick="SeleccionadosDataGrid_MouseDoubleClick"
                          SelectedItem="{Binding SelectedExpediente}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tipo Documento" Binding="{Binding TipoDoc}" CellStyle="{StaticResource TipoDocumentoCellStyle}"/>
                        <DataGridTextColumn Header="No Autorización" Binding="{Binding NoAutorizacion}"/>
                        <DataGridTextColumn Header="Fecha Creación" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}"/>
                        <DataGridTextColumn Header="Cobertura" Binding="{Binding Cobertura}"/>
                        <DataGridTextColumn Header="NIF Mutua" Binding="{Binding NIFMutua}"/>
                        <DataGridTextColumn Header="Nombre Paciente" Binding="{Binding NombrePaciente}"/>
                        <DataGridTextColumn Header="DNI Paciente" Binding="{Binding DNIPaciente}"/>
                        <DataGridTextColumn Header="Fecha Factura" Binding="{Binding FechaFactura, StringFormat=dd/MM/yyyy}"/>
                        <DataGridTextColumn Header="No Factura" Binding="{Binding NoFactura}"/>
                        <DataGridTextColumn Header="Fecha Acto" Binding="{Binding FechaActo, StringFormat=dd/MM/yyyy}"/>
                        <DataGridTextColumn Header="No Acto" Binding="{Binding NoActo}"/>
                        <DataGridTextColumn Header="Remesa" Binding="{Binding Remesa}"/>
                        <DataGridTextColumn Header="Cobertura Informe" Binding="{Binding CoberturaInforme}"/>
                        <DataGridTemplateColumn Header="Quitar">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveSeleccionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Background="{StaticResource DangerBrush}" Foreground="White" Padding="6,3">
                                        <Image Source="pack://application:,,,/GestorExpedientesWpf;component/Resources/delete.png" Width="16" Height="16"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Column="0">
                        <Button Content="Eliminar selección" Width="160" Background="{StaticResource DangerBrush}" Foreground="White"
                                Command="{Binding EliminarSeleccionCommand}" Padding="14,8"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                        <CheckBox Content="Asegurar triplete" IsChecked="{Binding AsegurarTriplete}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Asignar metadatos" Width="160" Background="{StaticResource PrimaryBrush}" Foreground="White"
                                Command="{Binding AsignarMetadatosCommand}" Padding="14,8"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- COLUMNA DERECHA - VISOR PDF -->
        <TabControl Grid.Column="1" Margin="8,16,16,16">
            <TabItem Header="Visor de Documento">
                <wv2:WebView2 Source="{Binding SelectedExpedienteUrl, Converter={StaticResource NullToDefaultUrlConverter}}"/>
            </TabItem>
        </TabControl>
    </Grid>

</Window>
