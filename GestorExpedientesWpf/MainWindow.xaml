<Window x:Class="GestorExpedientesWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:GestorExpedientesWpf"
        xmlns:viewModel="clr-namespace:GestorExpedientesWpf.ViewModels"
        xmlns:converters="clr-namespace:GestorExpedientesWpf.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Gestión de expedientes" MinHeight="900" MinWidth="1600"
        WindowState="Maximized"
        Background="{StaticResource PageBgBrush}" FontFamily="Segoe UI">

    <Window.DataContext>
        <viewModel:ExpedientesViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Modifiers="Control" Key="D0" Command="{Binding ZoomResetCommand}"/>
        <KeyBinding Modifiers="Control" Key="NumPad0" Command="{Binding ZoomResetCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleVisorCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <converters:NullToDefaultUrlConverter x:Key="NullToDefaultUrlConverter"/>

        <!-- Section title -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- Document type color coding -->
        <Style x:Key="TipoDocumentoCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Autorización">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Informe">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Factura">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Stats text -->
        <Style x:Key="CountTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Orphan row highlight -->
        <Style x:Key="OrphanRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOrphan}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Form styles -->
        <Style x:Key="FormTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- BooleanToContentConverter with edit/query modes -->
        <converters:BooleanToContentConverter x:Key="BooleanToContentConverter">
            <!-- MODO EDICIÓN -->
            <converters:BooleanToContentConverter.TrueContent>
                <Grid>
                    <GroupBox Margin="0,0,10,10">
                        <GroupBox.Header>
                            <TextBlock Text="Edición de metadatos" Style="{StaticResource SectionTitle}"/>
                        </GroupBox.Header>
                        <Grid Margin="10">
                            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    MaxWidth="1000" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="240"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="240"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Fila 0 -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="No. Autorización:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="5,4" MinWidth="150" MaxWidth="240" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoAutorizacion}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Fecha Factura:" Margin="20,8,5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <DatePicker Grid.Row="0" Grid.Column="3" Margin="5,4" Width="200" HorizontalAlignment="Left" FontSize="14"
                                                SelectedDate="{Binding EditExpediente.FechaFactura}"/>

                                    <!-- Fila 1 -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Nombre Paciente:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="5,4" MinWidth="240" MaxWidth="400" HorizontalAlignment="Stretch" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NombrePaciente}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="No. Factura:" Margin="20,8,5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" Margin="5,4" MinWidth="150" MaxWidth="240" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoFactura}"/>

                                    <!-- Fila 2 -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="DNI Paciente:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Margin="5,4" MinWidth="150" MaxWidth="240" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.DNIPaciente}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Remesa:" Margin="20,8,5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" Margin="5,4" MinWidth="150" MaxWidth="240" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.Remesa}"/>

                                    <!-- Fila 3 -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="NIF Mutua:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Margin="5,4" MinWidth="150" MaxWidth="240" HorizontalAlignment="Left" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NIFMutua}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Fecha Acto:" Margin="20,8,5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <DatePicker Grid.Row="3" Grid.Column="3" Margin="5,4" Width="200" HorizontalAlignment="Left" FontSize="14"
                                                SelectedDate="{Binding EditExpediente.FechaActo}"/>

                                    <!-- Fila 4 -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Cobertura:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Margin="5,4" MinWidth="240" MaxWidth="400" HorizontalAlignment="Stretch" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.Cobertura}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="No. Acto:" Margin="20,8,5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="4" Grid.Column="3" Margin="5,4" MinWidth="240" MaxWidth="400" HorizontalAlignment="Stretch" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.NoActo}"/>

                                    <!-- Fila 5: Cobertura Informe ocupa ancho completo -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Cobertura Informe:" Margin="5,8" VerticalAlignment="Center" Style="{StaticResource FormTextBlockStyle}"/>
                                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Margin="5,4" MinWidth="240" MaxWidth="900" HorizontalAlignment="Stretch" Style="{StaticResource FormTextBoxStyle}"
                                             Text="{Binding EditExpediente.CoberturaInforme}"/>

                                    <!-- Fila 6: Botones -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,16,0,0">
                                        <Button Content="Asignar" Command="{Binding SetMetadataCommand}" Background="{StaticResource PrimaryBrush}" Foreground="White" Margin="5" Padding="16,8"/>
                                        <Button Content="Cancelar" Command="{Binding CancelEditMetadataCommand}" Background="{StaticResource SplitterBrush}" Foreground="White" Margin="5" Padding="16,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </GroupBox>
                </Grid>
            </converters:BooleanToContentConverter.TrueContent>

            <converters:BooleanToContentConverter.FalseContent>
                <!-- MODO CONSULTA -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1" Margin="0,0,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Resultado consulta" Style="{StaticResource SectionTitle}" Grid.Row="0"/>

                        <xctk:BusyIndicator IsBusy="{Binding IsBusy}" BusyContent="Actualizando..." Grid.Row="1">
                            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding ExpedientesView}"
                                      IsReadOnly="True" RowStyle="{StaticResource OrphanRowStyle}"
                                      MouseDoubleClick="ResultadosDataGrid_MouseDoubleClick"
                                      SelectedItem="{Binding SelectedExpediente}"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tipo Documento" Binding="{Binding TipoDoc}" CellStyle="{StaticResource TipoDocumentoCellStyle}" Width="130"/>
                                    <DataGridTextColumn Header="No Autorización" Binding="{Binding NoAutorizacion}" Width="140"/>
                                    <DataGridTextColumn Header="Fecha Creación" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}" Width="110"/>
                                    <DataGridTextColumn Header="Cobertura" Binding="{Binding Cobertura}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="NIF Mutua" Binding="{Binding NIFMutua}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Nombre Paciente" Binding="{Binding NombrePaciente}" Width="*" MinWidth="250"/>
                                    <DataGridTextColumn Header="DNI Paciente" Binding="{Binding DNIPaciente}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Fecha Factura" Binding="{Binding FechaFactura, StringFormat=dd/MM/yyyy}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="No Factura" Binding="{Binding NoFactura}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Fecha Acto" Binding="{Binding FechaActo, StringFormat=dd/MM/yyyy}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="No Acto" Binding="{Binding NoActo}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Remesa" Binding="{Binding Remesa}" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="Cobertura Informe" Binding="{Binding CoberturaInforme}" Visibility="Collapsed"/>
                                    <DataGridTemplateColumn Header="Añadir" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.AddSeleccionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" Background="{StaticResource SuccessBrush}" Foreground="White" Padding="6,3">
                                                    <Image Source="pack://application:,,,/GestorExpedientesWpf;component/Resources/add.png" Width="16" Height="16"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </xctk:BusyIndicator>
                    </Grid>
                </Grid>
            </converters:BooleanToContentConverter.FalseContent>
        </converters:BooleanToContentConverter>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid x:Name="ContentRoot" Grid.Row="0">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale, FallbackValue=1}" ScaleY="{Binding UiScale, FallbackValue=1}"/>
            </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="11*" MinWidth="700"/>
            <ColumnDefinition Width="22"/>
            <ColumnDefinition x:Name="VisorColumn" Width="9*" MinWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- COLUMNA IZQUIERDA -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Panel de filtros -->
            <GroupBox Header="Selección de documentos" Grid.Row="0" Padding="10,6">
                <GroupBox.Style>
                    <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EditMetadataMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="Aplicar filtro de fechas" Margin="0,0,16,0" Name="chkFechaFiltro" IsChecked="{Binding AplicarFiltroFechas}"/>
                            <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaInicio}"/>
                            <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaFin}"/>
                            <Button Content="Actualizar" Margin="6,0,0,0" Width="100" Command="{Binding ActualizarCommand}"
                                    Background="{StaticResource PrimaryBrush}" Foreground="White" Click="Button_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Cobertura:" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBox x:Name="txtMutuas" Width="400" VerticalAlignment="Center" HorizontalAlignment="Left"
                                     Text="{Binding FiltroMutua, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="txtMutuas_KeyDown"
                                     MouseDoubleClick="txtMutuas_MouseDoubleClick"
                                     TextChanged="txtMutuas_TextChanged"/>
                            <Popup x:Name="popupMutuas"
                                   PlacementTarget="{Binding ElementName=txtMutuas}"
                                   Placement="Bottom" IsOpen="False" StaysOpen="False">
                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                    </Border.Effect>
                                    <ListBox x:Name="lstMutuas"
                                             ItemsSource="{Binding MutuasFiltradas}"
                                             MouseDoubleClick="lstMutuas_MouseDoubleClick"
                                             KeyDown="lstMutuas_KeyDown"
                                             MaxHeight="200"/>
                                </Border>
                            </Popup>
                            <CheckBox Content="Mostrar solo documentos huérfanos" IsChecked="{Binding MostrarSoloDocumentosHuerfanos}" Margin="20,0,16,0" VerticalAlignment="Center"/>
                            <CheckBox Content="Ignorar documentos con remesa" IsChecked="{Binding IgnorarDocumentosConRemesa}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Panel de estadísticas -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" Padding="16,12" CornerRadius="8">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding TotalDocumentos, StringFormat='Total expedientes: {0}'}"
                                           Style="{StaticResource CountTextStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding AutorizacionesCount, StringFormat='Autorizaciones: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource DangerBrush}"/>
                                    <TextBlock Text="{Binding InformesCount, StringFormat='Informes: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="{Binding FacturasCount, StringFormat='Facturas: {0}'}"
                                               Style="{StaticResource CountTextStyle}" Margin="6,0" Foreground="{StaticResource SuccessBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Resultados / Edición -->
            <ContentControl Grid.Row="1" Content="{Binding EditMetadataMode, Converter={StaticResource BooleanToContentConverter}}"/>

            <!-- Seleccionados -->
            <Grid Grid.Row="2" Margin="0,0,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Selección" Style="{StaticResource SectionTitle}" Grid.Row="0"/>
                <DataGrid AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Seleccionados}" Grid.Row="1"
                          RowStyle="{StaticResource OrphanRowStyle}" MouseDoubleClick="SeleccionadosDataGrid_MouseDoubleClick"
                          SelectedItem="{Binding SelectedExpediente}"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tipo Documento" Binding="{Binding TipoDoc}" CellStyle="{StaticResource TipoDocumentoCellStyle}" Width="130"/>
                        <DataGridTextColumn Header="No Autorización" Binding="{Binding NoAutorizacion}" Width="140"/>
                        <DataGridTextColumn Header="Fecha Creación" Binding="{Binding FechaCreacion, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Cobertura" Binding="{Binding Cobertura}" Width="*" MinWidth="200"/>
                        <DataGridTextColumn Header="NIF Mutua" Binding="{Binding NIFMutua}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Nombre Paciente" Binding="{Binding NombrePaciente}" Width="*" MinWidth="250"/>
                        <DataGridTextColumn Header="DNI Paciente" Binding="{Binding DNIPaciente}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Fecha Factura" Binding="{Binding FechaFactura, StringFormat=dd/MM/yyyy}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="No Factura" Binding="{Binding NoFactura}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Fecha Acto" Binding="{Binding FechaActo, StringFormat=dd/MM/yyyy}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="No Acto" Binding="{Binding NoActo}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Remesa" Binding="{Binding Remesa}" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Cobertura Informe" Binding="{Binding CoberturaInforme}" Visibility="Collapsed"/>
                        <DataGridTemplateColumn Header="Quitar" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveSeleccionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" Background="{StaticResource DangerBrush}" Foreground="White" Padding="6,3">
                                        <Image Source="pack://application:,,,/GestorExpedientesWpf;component/Resources/delete.png" Width="16" Height="16"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Column="0">
                        <Button Content="Eliminar selección" Width="160" Background="{StaticResource DangerBrush}" Foreground="White"
                                Command="{Binding EliminarSeleccionCommand}" Padding="14,8"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                        <CheckBox Content="Asegurar triplete" IsChecked="{Binding AsegurarTriplete}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="Asignar metadatos" Width="160" Background="{StaticResource PrimaryBrush}" Foreground="White"
                                Command="{Binding AsignarMetadatosCommand}" Padding="14,8"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <GridSplitter x:Name="VisorSplitter" Grid.Column="1" Width="6" HorizontalAlignment="Center" Background="{StaticResource SplitterBrush}"
                      ToolTip="Ajustar tamaño" Cursor="SizeWE">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsVisorColapsado}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="0,16"/>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- Botón colapsar/expandir visor (overlay sobre el splitter) -->
        <ToggleButton Grid.Column="1" IsChecked="{Binding IsVisorColapsado, Mode=TwoWay}"
                      Width="22" Height="56" VerticalAlignment="Center" HorizontalAlignment="Center"
                      Cursor="Hand" Panel.ZIndex="10"
                      ToolTip="Colapsar/expandir visor (F11)" Focusable="False">
            <ToggleButton.Style>
                <Style TargetType="ToggleButton">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                                    <TextBlock x:Name="Icon" Text="&#x276E;" Foreground="{TemplateBinding Foreground}"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Icon" Property="Text" Value="&#x276F;"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ToggleButton.Style>
        </ToggleButton>

        <!-- COLUMNA DERECHA - VISOR PDF -->
        <TabControl Grid.Column="2" Margin="8,16,16,16">
            <TabItem Header="Visor de Documento">
                <wv2:WebView2 Source="{Binding SelectedExpedienteUrl, Converter={StaticResource NullToDefaultUrlConverter}}"/>
            </TabItem>
        </TabControl>
        </Grid>

        <!-- Status bar inferior (fuera del LayoutTransform) -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,2">
            <Border.Resources>
                <Style x:Key="ZoomButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#x2212;" Width="28" Height="24" Command="{Binding ZoomOutCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="14" FontWeight="Bold"
                        ToolTip="Reducir (Ctrl + −)"/>
                <Button Content="{Binding UiScalePercent}" MinWidth="52" Height="24" Command="{Binding ZoomResetCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="12"
                        ToolTip="Restablecer 100% (Ctrl + 0)"/>
                <Button Content="&#x002B;" Width="28" Height="24" Command="{Binding ZoomInCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="14" FontWeight="Bold"
                        ToolTip="Ampliar (Ctrl + +)"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
