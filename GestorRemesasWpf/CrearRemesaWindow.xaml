<Window x:Class="GestorRemesasWpf.CrearRemesaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorRemesasWpf"
        xmlns:vm="clr-namespace:GestorRemesasWpf.ViewModels"
        xmlns:converters="clr-namespace:GestorRemesasWpf.Converters"
        mc:Ignorable="d"
        Title="Crear Remesa" Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource PageBgBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:CrearRemesaViewModel/>
    </Window.DataContext>

    <Grid Margin="24">
        <Border Background="{StaticResource CardBgBrush}" CornerRadius="12" Padding="28,24"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="16" ShadowDepth="3" Direction="270"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <!-- Título -->
                <TextBlock Text="Crear Remesa" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                <!-- Campo Remesa -->
                <TextBlock Text="Remesa" FontSize="13" FontWeight="Medium" Margin="0,0,0,6"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBox x:Name="txtRemesa" FontSize="14" Height="34"
                         Text="{Binding Remesa, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Campo Tipo Exportación -->
                <TextBlock Text="Tipo Exportación" FontSize="13" FontWeight="Medium" Margin="0,16,0,6"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ComboBox x:Name="comboTipoExportacion" FontSize="14" Height="34"
                          SelectedItem="{Binding TipoExportacion, Mode=TwoWay}">
                    <ComboBoxItem Content="Adeslas"/>
                    <ComboBoxItem Content="Asisa"/>
                    <ComboBoxItem Content="Factura"/>
                    <ComboBoxItem Content="Mapfre"/>
                    <ComboBoxItem Content="Sanitas"/>
                </ComboBox>

                <!-- Barra de Progreso -->
                <TextBlock Text="Progreso" FontSize="13" FontWeight="Medium" Margin="0,20,0,6"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ProgressBar x:Name="progressBar" Height="10" Value="{Binding Progreso}">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border Background="{StaticResource RowAltBrush}" CornerRadius="5"/>
                                <Border x:Name="PART_Indicator" Background="{StaticResource PrimaryBrush}" CornerRadius="5"
                                        HorizontalAlignment="Left"/>
                                <Border x:Name="PART_Track"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>

                <!-- Botones -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
                    <Button Content="Cancelar" Width="110" Background="{StaticResource SplitterBrush}" Foreground="White"
                            Padding="14,9" Click="Cancelar_Button_Click"/>
                    <Button Content="Iniciar" Width="110" Margin="10,0,0,0" Background="{StaticResource PrimaryBrush}" Foreground="White"
                            Padding="14,9" Command="{Binding CrearRemesaCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
