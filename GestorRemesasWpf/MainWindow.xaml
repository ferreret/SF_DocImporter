<Window x:Class="GestorRemesasWpf.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
       xmlns:local="clr-namespace:GestorRemesasWpf"
       xmlns:vm="clr-namespace:GestorRemesasWpf.ViewModels"
       xmlns:converters="clr-namespace:GestorRemesasWpf.Converters"
       xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
       mc:Ignorable="d"
       Title="Gestión de remesas" MinHeight="900" MinWidth="1600"
       WindowState="Maximized"
       Background="{StaticResource PageBgBrush}" FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:ExpedienteViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Modifiers="Control" Key="D0" Command="{Binding ZoomResetCommand}"/>
        <KeyBinding Modifiers="Control" Key="NumPad0" Command="{Binding ZoomResetCommand}"/>
        <KeyBinding Key="F11" Command="{Binding ToggleVisorCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:NullToDefaultUrlConverter x:Key="NullToDefaultUrlConverter"/>

        <!-- Document type color coding -->
        <Style x:Key="TipoDocumentoCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Autorización">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Informe">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TipoDoc}" Value="Factura">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Invoice status -->
        <Style x:Key="NoFacturaCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsFacturaCargada}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsFacturaOrphan}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsFacturaInvalida}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CodigoRemesaCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsFacturaInvalida}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoAutorizacionCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsFacturaSinAutorizacion}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InformeCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsFacturaSinInforme}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid x:Name="ContentRoot" Grid.Row="0">
            <Grid.LayoutTransform>
                <ScaleTransform ScaleX="{Binding UiScale, FallbackValue=1}" ScaleY="{Binding UiScale, FallbackValue=1}"/>
            </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="22"/>
            <ColumnDefinition x:Name="VisorColumn" Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- COLUMNA IZQUIERDA -->
        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Panel de filtros -->
            <GroupBox Header="Selección de fechas" Grid.Row="0" Padding="10,6">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="Aplicar filtro de fechas" Margin="0,0,12,0" Name="chkFechaFiltro" IsChecked="{Binding AplicarFiltroFechas}"/>
                        <TextBlock Text="Desde:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaInicio}"/>
                        <TextBlock Text="Hasta:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <DatePicker Width="120" IsEnabled="{Binding ElementName=chkFechaFiltro, Path=IsChecked}" Margin="0,0,10,0" SelectedDate="{Binding FechaFin}"/>
                        <Button Content="Actualizar" Margin="6,0,0,0" Width="100" Background="{StaticResource PrimaryBrush}" Foreground="White" Command="{Binding ActualizarCommand}"/>
                        <Button Content="Borrar" Margin="8,0,0,0" Width="100" Background="{StaticResource DangerBrush}" Foreground="White" Command="{Binding BorrarExpedientesCommand}"/>
                    </StackPanel>

                    <!-- Sub-fila A: Coberturas + Modos de filtrado en la misma linea -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Coberturas:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox x:Name="txtMutuas" Width="260" VerticalAlignment="Center" HorizontalAlignment="Left"
                                 Text="{Binding FiltroMutua, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="txtMutuas_TextChanged"
                                 KeyDown="txtMutuas_KeyDown"
                                 MouseDoubleClick="txtMutuas_MouseDoubleClick"/>
                        <Popup x:Name="popupMutuas"
                               PlacementTarget="{Binding ElementName=txtMutuas}"
                               Placement="Bottom" IsOpen="False" StaysOpen="False">
                            <Border Background="White" BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="6">
                                <ListBox x:Name="lstMutuas"
                                         MouseDoubleClick="lstMutuas_MouseDoubleClick"
                                         KeyDown="lstMutuas_KeyDown"
                                         MaxHeight="200"/>
                            </Border>
                        </Popup>
                        <RadioButton Content="Todos" GroupName="RemesaFilter" Margin="16,0,0,0" VerticalAlignment="Center" IsChecked="{Binding RemesaFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:RemesaFilter.Todos}}"/>
                        <RadioButton Content="Sin Remesa" GroupName="RemesaFilter" Margin="10,0,0,0" VerticalAlignment="Center" IsChecked="{Binding RemesaFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:RemesaFilter.SinRemesa}}"/>
                        <RadioButton Content="Con Remesa" GroupName="RemesaFilter" Margin="10,0,0,0" VerticalAlignment="Center" IsChecked="{Binding RemesaFilter, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static vm:RemesaFilter.ConRemesa}}"/>
                        <CheckBox Content="Solo huérfanos" IsChecked="{Binding IsOrphanFilter, Mode=TwoWay}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Solo facturas" IsChecked="{Binding IsFacturaFilter, Mode=TwoWay}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Selector de archivo -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                        <Button Content="Seleccionar archivo Facturas" Background="{StaticResource SuccessBrush}" Foreground="White"
                                Command="{Binding SeleccionarArchivoCommand}" Padding="12,5"/>
                        <TextBlock Text="{Binding NombreArchivo}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{Binding ColorMensajeArchivo}"/>
                        <CheckBox Content="Mostrar solo Facturas del archivo"
                                  IsChecked="{Binding MostrarSoloFacturasDelArchivo, Mode=TwoWay}"
                                  Visibility="{Binding NombreArchivo, Converter={StaticResource StringToVisibilityConverter}}"
                                  Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- DataGrid -->
            <xctk:BusyIndicator Grid.Row="1" IsBusy="{Binding IsBusy}" BusyContent="Actualizando...">
                <DataGrid x:Name="ExpedientesDataGrid" ItemsSource="{Binding ExpedientesFiltrados}"
                          AutoGenerateColumns="False" Margin="0,4,0,0" CanUserAddRows="False" SelectedItem="{Binding SelectedExpediente}"
                          HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="No Factura" Binding="{Binding NoFactura}" CellStyle="{StaticResource NoFacturaCellStyle}" Width="110"/>
                        <DataGridTextColumn Header="Tipo Doc" Binding="{Binding TipoDoc}" CellStyle="{StaticResource TipoDocumentoCellStyle}" Width="100"/>
                        <DataGridTextColumn Header="Fecha Factura" Binding="{Binding FechaFactura, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                        <DataGridTextColumn Header="Fecha Acto" Binding="{Binding FechaActo, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                        <DataGridTextColumn Header="No Acto" Binding="{Binding NoActo}" Width="100"/>
                        <DataGridTextColumn Header="No Autorización" Binding="{Binding NoAutorizacion}" CellStyle="{StaticResource NoAutorizacionCellStyle}" Width="130"/>
                        <DataGridTextColumn Header="Fecha Creación" Binding="{Binding FechaCreacion, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                        <DataGridTextColumn Header="Cobertura" Binding="{Binding Cobertura}" Width="*" MinWidth="180"/>
                        <DataGridTextColumn Header="NIF Mutua" Binding="{Binding NIFMutua}" Width="100"/>
                        <DataGridTextColumn Header="Nombre Paciente" Binding="{Binding NombrePaciente}" Width="*" MinWidth="200"/>
                        <DataGridTextColumn Header="DNI Paciente" Binding="{Binding DNIPaciente}" Width="100"/>
                        <DataGridTextColumn Header="Remesa" Binding="{Binding Remesa}" CellStyle="{StaticResource CodigoRemesaCellStyle}" Width="90"/>
                        <DataGridTextColumn Header="Cobertura Informe" Binding="{Binding CoberturaInforme}" CellStyle="{StaticResource InformeCellStyle}" Width="*" MinWidth="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </xctk:BusyIndicator>

            <!-- Botones de acción -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="Exportar a CSV" Width="130" Height="38" Background="{StaticResource PrimaryBrush}" Foreground="White"
                            Command="{Binding ExportarCsvCommand}"/>
                    <Button Content="Exportar a Excel" Width="130" Height="38" Background="{StaticResource PrimaryBrush}" Foreground="White"
                            Command="{Binding ExportarExcelCommand}" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Crear Remesa" Background="{StaticResource SuccessBrush}" Foreground="White"
                            Height="38" Command="{Binding CrearRemesaCommand}" Padding="20,7"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Splitter -->
        <GridSplitter x:Name="VisorSplitter" Grid.Column="1" Width="6" HorizontalAlignment="Center" Cursor="SizeWE">
            <GridSplitter.Style>
                <Style TargetType="GridSplitter">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsVisorColapsado}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </GridSplitter.Style>
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{StaticResource SplitterBrush}" CornerRadius="3" Margin="0,16"/>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- Botón colapsar/expandir visor (overlay sobre el splitter) -->
        <ToggleButton Grid.Column="1" IsChecked="{Binding IsVisorColapsado, Mode=TwoWay}"
                      Width="22" Height="56" VerticalAlignment="Center" HorizontalAlignment="Center"
                      Cursor="Hand" Panel.ZIndex="10"
                      ToolTip="Colapsar/expandir visor (F11)" Focusable="False">
            <ToggleButton.Style>
                <Style TargetType="ToggleButton">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                                    <TextBlock x:Name="Icon" Text="&#x276E;" Foreground="{TemplateBinding Foreground}"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Icon" Property="Text" Value="&#x276F;"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ToggleButton.Style>
        </ToggleButton>

        <!-- COLUMNA DERECHA - VISOR PDF -->
        <TabControl Grid.Column="2" Margin="8,16,16,16">
            <TabItem Header="Visor de Documento">
                <wv2:WebView2 Source="{Binding SelectedExpedienteUrl, Converter={StaticResource NullToDefaultUrlConverter}}"/>
            </TabItem>
        </TabControl>
        </Grid>

        <!-- Status bar inferior (fuera del LayoutTransform) -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="0,1,0,0" Padding="12,2">
            <Border.Resources>
                <Style x:Key="ZoomButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#x2212;" Width="28" Height="24" Command="{Binding ZoomOutCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="14" FontWeight="Bold"
                        ToolTip="Reducir (Ctrl + −)"/>
                <Button Content="{Binding UiScalePercent}" MinWidth="52" Height="24" Command="{Binding ZoomResetCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="12"
                        ToolTip="Restablecer 100% (Ctrl + 0)"/>
                <Button Content="&#x002B;" Width="28" Height="24" Command="{Binding ZoomInCommand}"
                        Style="{StaticResource ZoomButtonStyle}" FontSize="14" FontWeight="Bold"
                        ToolTip="Ampliar (Ctrl + +)"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
